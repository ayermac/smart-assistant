# Phase 1 does not call model providers yet; provider/model are reserved for Phase 2.
SMART_ASSISTANT_DATA_DIR=.smart-assistant

# LLM Provider Configuration (Phase 2+)
# Provider: "anthropic" (default) or "openai"
SMART_ASSISTANT_PROVIDER=
# Model ID: e.g., "claude-sonnet-4-20250514" or "gpt-4o"
SMART_ASSISTANT_MODEL=

# Anthropic Configuration (required if SMART_ASSISTANT_PROVIDER=anthropic or unset)
ANTHROPIC_API_KEY=

# OpenAI Configuration (required if SMART_ASSISTANT_PROVIDER=openai)
OPENAI_API_KEY=
# Optional: Override base URL for OpenAI-compatible endpoints (Ollama, vLLM, etc.)
# OPENAI_BASE_URL=http://localhost:11434/v1
