# Phase 1 does not call model providers yet; provider/model are reserved for Phase 2.
SMART_ASSISTANT_DATA_DIR=.smart-assistant

# Knowledge Source Directory (Phase 5+)
# Directory containing local Markdown/text files for RAG knowledge ingestion.
# Defaults to {SMART_ASSISTANT_DATA_DIR}/knowledge-sources if not set.
# SMART_ASSISTANT_KNOWLEDGE_DIR=

# LLM Provider Configuration (Phase 2+)
# Provider: "anthropic" (default) or "openai"
SMART_ASSISTANT_PROVIDER=openai
# Model ID: e.g., "claude-sonnet-4-20250514" or "doubao-seed-2.0-lite"
SMART_ASSISTANT_MODEL=doubao-seed-2.0-lite

# Anthropic Configuration (required if SMART_ASSISTANT_PROVIDER=anthropic)
ANTHROPIC_API_KEY=

# OpenAI/Doubao Configuration (required if SMART_ASSISTANT_PROVIDER=openai)
OPENAI_API_KEY=your-api-key
# Optional: Override base URL for OpenAI-compatible endpoints (Doubao, Ollama, vLLM, etc.)
OPENAI_BASE_URL=https://ark.cn-beijing.volces.com/api/coding/v3

# Embedding Configuration (Phase 8+)
# Used for both Memory and Knowledge RAG semantic search.
# Base URL for embedding API (default: Doubao endpoint)
EMBEDDING_BASE_URL=https://ark.cn-beijing.volces.com/api/coding/v3
# Model for embeddings (default: doubao-embedding-vision, produces 2048-dim vectors)
EMBEDDING_MODEL=doubao-embedding-vision
# Note: Embedding API key uses OPENAI_API_KEY (shared with LLM)

# Obsidian Vault Configuration (Phase 10+)
# Path to Obsidian vault for real-time file watching and multimodal RAG.
# When configured, the CLI will sync the vault on startup and watch for changes.
# OBSIDIAN_VAULT_PATH=/path/to/your/obsidian/vault

# Reranking Configuration (Phase 11+)
# Reranking improves search relevance by reordering results using a cross-encoder model.
# Enable reranking (default: false)
# RERANK_ENABLED=true
# Reranker provider: "noop" (disabled) or "cohere" (default: noop)
# RERANK_PROVIDER=cohere
# Cohere API key for reranking (required if RERANK_PROVIDER=cohere)
# COHERE_API_KEY=your-cohere-api-key
# Cohere rerank model (optional, default: rerank-english-v3.0)
# COHERE_RERANK_MODEL=rerank-english-v3.0
# Cohere API base URL (optional, default: https://api.cohere.ai/v1)
# COHERE_RERANK_BASE_URL=
