{
  "name": "smart-assistant",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "smart-assistant": "./dist/cli.js",
    "smart-assistant-tui": "./dist/tui.js"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "tui": "tsx src/tui.tsx",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "start": "node dist/cli.js",
    "eval": "tsx scripts/eval.ts"
  },
  "engines": {
    "node": ">=22.19.0"
  },
  "dependencies": {
    "@earendil-works/pi-agent-core": "^0.75.4",
    "@earendil-works/pi-ai": "^0.75.4",
    "@lancedb/lancedb": "^0.29.0",
    "@langchain/community": "^1.1.28",
    "@langchain/core": "^1.1.48",
    "@sinclair/typebox": "^0.34.0",
    "apache-arrow": "^21.1.0",
    "chokidar": "^5.0.0",
    "dotenv": "^17.4.2",
    "ink": "^7.0.5",
    "mammoth": "^1.12.0",
    "pdf-parse": "^2.4.5",
    "react": "^19.2.7"
  },
  "devDependencies": {
    "@types/node": "^24.12.4",
    "@types/react": "^19.2.17",
    "tsx": "^4.22.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.7"
  }
}
